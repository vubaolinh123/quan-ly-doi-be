NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/cong-tac-cshs
JWT_SECRET=super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@cshs.local
ADMIN_PASSWORD=Admin@123456

# Facebook
FACEBOOK_VERIFY_TOKEN=your_fb_verify_token
FACEBOOK_PAGE_ACCESS_TOKEN=your_fb_page_access_token
FACEBOOK_APP_SECRET=your_fb_app_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Telegram — Bot gửi thông báo vào nhóm chat chung
# Bước cài đặt:
#   1. Tạo bot qua @BotFather trên Telegram → nhận TELEGRAM_BOT_TOKEN
#   2. Tạo 1 nhóm (Group) hoặc kênh (Channel), thêm bot vào nhóm
#   3. Cấp quyền "Send Messages" cho bot trong nhóm (Admin > Manage Group)
#   4. Lấy Group Chat ID (số ÂM, vd: -1001234567890):
#      - Thêm @userinfobot vào nhóm → gõ lệnh bất kỳ → nó trả về chat.id
#      - Hoặc dùng: https://api.telegram.org/bot<TOKEN>/getUpdates sau khi gửi 1 tin nhắn vào nhóm
#   5. Paste Group Chat ID vào TELEGRAM_GROUP_CHAT_ID bên dưới
#   6. Đặt TELEGRAM_WEBHOOK_SECRET tùy ý (chuỗi bí mật để xác thực callback)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_GROUP_CHAT_ID=your_telegram_group_chat_id
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# Batching
MESSAGE_BATCH_WINDOW_MS=5000
